# OpenTelemetry Configuration for Docker Compose setup
# Set the OTLP exporter endpoint to send traces to the collector

# For local Docker Compose setup
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Alternative: If running the app inside Docker network, use:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Service identification
OTEL_SERVICE_NAME=demo-ecom-app
DEPLOYMENT_ENV=development

# Node.js specific
NODE_ENV=development
NODE_OPTIONS=--max-old-space-size=512
